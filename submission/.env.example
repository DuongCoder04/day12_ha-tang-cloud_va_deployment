# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=DuongCoder04 AI Agent
APP_VERSION=1.0.0

# LLM — OpenRouter (chat thật). Bỏ trống = dùng mock LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
LLM_MODEL=gpt-4o-mini

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Chat UI — password bảo vệ giao diện /chat
CHAT_PASSWORD=duong2024

# Rate & Budget
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000
